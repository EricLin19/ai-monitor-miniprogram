<view class="page">
  <view class="hero">
    <view>
      <view class="eyebrow">AI 景气度雷达</view>
      <view class="title">18 个核心指标</view>
      <view class="desc">需求、商业化、算力投入、效率和供应链收入一起看。</view>
    </view>
    <view class="health {{healthClass}}">
      <text>{{healthLabel}}</text>
    </view>
  </view>

  <view class="toolbar">
    <input class="search" value="{{keyword}}" bindinput="onSearch" placeholder="搜索指标 / 来源 / 公司" />
    <button class="refresh" loading="{{loading}}" bindtap="loadMetrics">刷新</button>
  </view>

  <view class="meta">
    <text>更新时间：{{updatedAt}}</text>
    <text>数据模式：{{source}}</text>
  </view>

  <view wx:if="{{errorMessage}}" class="debug">
    {{errorMessage}}
  </view>

  <view class="tabs">
    <view class="tab {{activeGroup === 'all' ? 'active' : ''}}" data-group="all" bindtap="changeGroup">全部</view>
    <view class="tab {{activeGroup === 'AI Demand' ? 'active' : ''}}" data-group="AI Demand" bindtap="changeGroup">需求</view>
    <view class="tab {{activeGroup === 'AI Monetization' ? 'active' : ''}}" data-group="AI Monetization" bindtap="changeGroup">商业化</view>
    <view class="tab {{activeGroup === 'AI Infrastructure' ? 'active' : ''}}" data-group="AI Infrastructure" bindtap="changeGroup">算力</view>
    <view class="tab {{activeGroup === 'AI Stress' ? 'active' : ''}}" data-group="AI Stress" bindtap="changeGroup">压力</view>
    <view class="tab {{activeGroup === 'AI Valuation Heatmap' ? 'active' : ''}}" data-group="AI Valuation Heatmap" bindtap="changeGroup">温度</view>
  </view>

  <view class="cards">
    <view wx:for="{{visibleMetrics}}" wx:key="id" class="card" bindtap="openSource" data-url="{{item.sourceUrl}}">
      <view class="cardTop">
        <view>
          <view class="group">{{item.group}} · {{item.cadence}}</view>
          <view class="name">{{item.title}}</view>
        </view>
        <view class="badge {{item.accessClass}}">{{item.access}}</view>
      </view>

      <view class="metricLine">
        <view>
          <text class="value">{{item.value}}</text>
          <text class="unit">{{item.unit}}</text>
        </view>
        <view class="change {{item.trend}}">{{item.change}}</view>
      </view>

      <view class="note">{{item.note}}</view>

      <view class="sourceLine">
        <text>{{item.source}}</text>
        <text>查看</text>
      </view>
    </view>
  </view>
</view>
