<view class="page">
  <view class="hero">
    <view>
      <view class="eyebrow">AI 景气度雷达</view>
      <view class="title">{{displayMetricCount}} 个核心指标</view>
      <view class="desc">按中金框架跟踪：需求、现金流、资金来源、外部约束。</view>
    </view>
    <view class="health {{healthClass}}">
      <text>{{healthLabel}}</text>
    </view>
  </view>

  <view class="toolbar">
    <input class="search" value="{{keyword}}" bindinput="onSearch" placeholder="搜索指标 / 来源 / 公司" />
    <button class="refresh" loading="{{loading}}" bindtap="loadMetrics">刷新</button>
  </view>

  <view class="meta">
    <text>更新时间：{{updatedAt}}</text>
    <text>数据模式：{{source}}</text>
  </view>

  <view wx:if="{{errorMessage}}" class="debug">
    {{errorMessage}}
  </view>

  <view class="tabs">
    <view class="tab {{activeGroup === 'all' ? 'active' : ''}}" data-group="all" bindtap="changeGroup">全部</view>
    <view class="tab {{activeGroup === '① 需求' ? 'active' : ''}}" data-group="① 需求" bindtap="changeGroup">① 需求</view>
    <view class="tab {{activeGroup === '② 现金流' ? 'active' : ''}}" data-group="② 现金流" bindtap="changeGroup">② 现金流</view>
    <view class="tab {{activeGroup === '③ 资金来源' ? 'active' : ''}}" data-group="③ 资金来源" bindtap="changeGroup">③ 资金来源</view>
    <view class="tab {{activeGroup === '④ 外部约束' ? 'active' : ''}}" data-group="④ 外部约束" bindtap="changeGroup">④ 外部约束</view>
  </view>

  <view class="cards">
    <view wx:for="{{visibleMetrics}}" wx:key="id" class="card" bindtap="openDetail" data-id="{{item.id}}">
      <view class="cardTop">
        <view>
          <view class="group">{{item.group}} · {{item.cadence}}</view>
          <view class="name">{{item.title}}</view>
        </view>
        <view class="badge {{item.accessClass}}">{{item.access}}</view>
      </view>

      <view class="metricLine">
        <view>
          <text class="value">{{item.value}}</text>
          <text class="unit">{{item.unit}}</text>
        </view>
        <view class="change {{item.trend}}">{{item.change}}</view>
      </view>

      <view class="chartBlock" catchtap="noop">
        <view class="chartHead">
          <text>{{item.windowLabel}}</text>
          <text>{{item.historyLabel}}</text>
        </view>
        <canvas class="sparkCanvas" canvas-id="{{item.canvasId}}" id="{{item.canvasId}}"></canvas>
      </view>

      <view class="note">{{item.note}}</view>

      <view class="sourceLine">
        <text>{{item.source}}</text>
        <text>详情</text>
      </view>
    </view>
  </view>
</view>
